<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Mini Mario Kart 🏎️</title>
<script src="https://cdn.jsdelivr.net/npm/phaser@3/dist/phaser.js"></script>
<style>
  body { margin: 0; background: #222; }
</style>
</head>
<body>

<script>
const config = {
  type: Phaser.AUTO,
  width: 400,
  height: 600,
  physics: {
    default: 'arcade'
  },
  scene: {
    preload,
    create,
    update
  }
};

let player;
let cursors;
let road;

const game = new Phaser.Game(config);

// carregar imagens
function preload() {
  this.load.image('car', 'https://i.imgur.com/7QFQFQY.png');
  this.load.image('road', 'https://i.imgur.com/3e5pQ7Y.png');
}

// criar elementos
function create() {
  // estrada (tile infinito)
  road = this.add.tileSprite(200, 300, 400, 600, 'road');

  // player
  player = this.physics.add.sprite(200, 500, 'car');
  player.setScale(0.5);

  // controles
  cursors = this.input.keyboard.createCursorKeys();
}

// atualizar jogo
function update() {
  // movimentar estrada (efeito corrida)
  road.tilePositionY -= 5;

  // movimento lateral
  if (cursors.left.isDown) {
    player.x -= 5;
  }
  if (cursors.right.isDown) {
    player.x += 5;
  }

  // limites da pista
  if (player.x < 80) player.x = 80;
  if (player.x > 320) player.x = 320;
}
</script>

</body>
</html>
